<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_shell">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_card"
        android:alpha="0.4" />

    <View
        android:id="@+id/scanLine"
        android:layout_width="220dp"
        android:layout_height="6dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_scan_line" />

    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:src="@drawable/ic_security"
            android:tint="@color/neon_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Screen Recording Detection Tool"
            android:textColor="@color/ink_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Initializing Security Scan..."
            android:textColor="@color/gray_text"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
