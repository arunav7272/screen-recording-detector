<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_alert_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@android:drawable/ic_dialog_alert"
        android:tint="@color/ui_alert_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Screen Recording Detected!"
        android:textColor="@color/ui_alert_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/ivRiskAppIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="18dp"
        android:src="@android:drawable/ic_dialog_info" />

    <TextView
        android:id="@+id/tvRiskAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="App Name"
        android:textColor="@color/ui_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRiskMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Recording risk detected while this app was open."
        android:textColor="@color/text_secondary_soft"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Block Screen"
        android:textAllCaps="false"
        app:cornerRadius="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenHistory"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Ignore"
        android:textAllCaps="false"
        app:cornerRadius="14dp" />

</LinearLayout>
